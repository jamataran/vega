# ─────────────────────────────────────────────────────────────
#  Vega — variables de entorno
#  Copia este fichero a .env y ajusta lo que necesites.
#
#  Se cargan todos los ficheros que existan, de menor a mayor
#  precedencia: .env de la raíz, apps/api/.env y, por último,
#  .env.local. El último gana.
#
#  .env.local está en .gitignore y es donde van las credenciales
#  de cada desarrollador —el Moodle de pruebas, la clave real de
#  Anthropic—, para poder pisar el .env compartido sin editarlo.
#
#  Y una regla que manda sobre todo esto: lo que se pueda editar
#  en Ajustes vive en la tabla app_settings, y app_settings gana
#  al entorno. Estas variables son el valor de partida de una
#  instalación nueva, no la configuración de una en marcha.
# ─────────────────────────────────────────────────────────────

# Base de datos ------------------------------------------------
# El 5433 es el puerto que expone docker-compose.yml en local.
DATABASE_URL=postgres://vega:vega@localhost:5433/vega

# API ----------------------------------------------------------
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# Secreto de firma de JWT. En producción, genera uno largo y aleatorio:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=dev-secret-cambiame-en-produccion-por-favor
JWT_EXPIRES_IN=12h

# Origen permitido para CORS (el dev server de la PWA).
WEB_ORIGIN=http://localhost:5174

# IA -----------------------------------------------------------
# mock      → respuestas simuladas, sin coste y sin clave (por defecto en dev)
# anthropic → llamadas reales a la API de Anthropic
# Editable en Ajustes; lo de aquí sólo cuenta si app_settings está vacío.
AI_PROVIDER=mock
# ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL_TRANSCRIPTION=claude-opus-4-8
AI_MODEL_GRADING=claude-opus-4-8

# Conector LMS -------------------------------------------------
# mock       → cursos, actividades y entregas simuladas en memoria (por defecto en dev)
# filesystem → lee entregas de un directorio local
# moodle3    → Moodle 3.x vía web services
# El conector y la URL son de la instalación, y se editan en Ajustes.
LMS_CONNECTOR=mock
# LMS_FILESYSTEM_ROOT=./data/entregas
# MOODLE_BASE_URL=https://moodle.ejemplo.es

# El token de Moodle NO es configuración de producción.
#
# Es de cada usuario, no de la instalación: core_enrol_get_users_courses
# devuelve los cursos del dueño del token, así que la credencial decide qué
# cursos ve cada profesor. Se guarda en users.moodle_token y se pega desde
# Ajustes; un administrador puede además ponerlo desde la ficha del usuario.
# Ningún camino de la aplicación lee esta variable en ejecución.
#
# Lo único que hace MOODLE_TOKEN es dar arranque en frío al desarrollo:
# `pnpm db:seed` se lo asigna a los dos usuarios de ejemplo, para no tener que
# volver a pegarlo a mano después de cada siembra. Ponlo en .env.local.
#
# Ver docs/decisiones/0010-credencial-moodle-por-usuario.md
# MOODLE_TOKEN=

# Correo (resúmenes nocturnos) --------------------------------
# Editable en Ajustes.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=vega@ejemplo.es

# Marca --------------------------------------------------------
BRAND_NAME=Vega

# ── Administrador inicial ────────────────────────────────────────────────────
# Se crea SÓLO si la base de datos no tiene ningún usuario, y nunca vuelve a
# tocarse: no recrea al admin borrado ni le devuelve la contraseña de fábrica.
# Cámbiala al primer arranque — el API avisa en cada arranque mientras siga la
# de por defecto. El resto de usuarios se dan de alta desde la aplicación.
BOOTSTRAP_ADMIN_EMAIL=admin@vega.local
BOOTSTRAP_ADMIN_PASSWORD=admin
