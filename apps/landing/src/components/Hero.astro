---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative pt-32 pb-20 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col items-center text-center">
    
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[var(--vega-violet-400)]/30 bg-[var(--vega-violet-400)]/10 text-[var(--vega-violet-600)] text-xs font-medium mb-8">
      <span>Open Source</span>
      <span class="w-1 h-1 rounded-full bg-[var(--vega-violet-500)]"></span>
      <span>Moodle Plugin</span>
    </div>

    <h1 class="font-display font-semibold text-5xl md:text-7xl tracking-tight text-[var(--color-text)] max-w-4xl mx-auto leading-[1.1] mb-6">
      {t('hero.title').split('.')[0]}. <br />
      <span class="text-gradient">{t('hero.title').split('.')[1]}.</span>
    </h1>
    
    <p class="text-[var(--color-text-muted)] text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
      {t('hero.subtitle')}
    </p>
    
    <div class="flex flex-col sm:flex-row items-center gap-4">
      <a href="https://github.com/jamataran/vega" class="bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-white px-8 py-4 rounded-[var(--radius-vega-md)] text-base font-medium transition-all shadow-[var(--shadow-vega-raised)] hover:-translate-y-0.5 flex items-center gap-2 w-full sm:w-auto justify-center">
        {t('hero.cta')}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </a>
      <a href="#features" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] px-8 py-4 text-base font-medium transition-colors w-full sm:w-auto justify-center text-center">
        {t('nav.features')}
      </a>
    </div>

  </div>
  
  <!-- Subtle background decoration (strictly following guidelines: no generic AI tropes, no heavy glow) -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-tr from-[var(--vega-violet-400)]/5 to-[var(--vega-cyan-400)]/5 rounded-full blur-3xl -z-10 pointer-events-none"></div>
</section>
