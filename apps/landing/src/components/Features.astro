---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  {
    title: t('features.1.title'),
    desc: t('features.1.desc'),
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`
  },
  {
    title: t('features.2.title'),
    desc: t('features.2.desc'),
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`
  },
  {
    title: t('features.3.title'),
    desc: t('features.3.desc'),
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>`
  }
];
---

<section id="features" class="py-24 bg-[var(--color-bg)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-16">
      <h2 class="font-display font-semibold text-3xl md:text-4xl text-[var(--color-text)] mb-4">
        {t('features.title')}
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {features.map(feature => (
        <div class="p-8 rounded-[var(--radius-vega-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-sm hover:shadow-[var(--shadow-vega-raised)] transition-all flex flex-col items-start text-left">
          <div class="w-12 h-12 rounded-[var(--radius-vega-md)] bg-[var(--vega-cloud-50)] text-[var(--vega-violet-600)] flex items-center justify-center mb-6 border border-[var(--color-border)]" set:html={feature.icon}>
          </div>
          <h3 class="font-display font-semibold text-xl text-[var(--color-text)] mb-3">
            {feature.title}
          </h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            {feature.desc}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
