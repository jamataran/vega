# ─────────────────────────────────────────────────────────────────────────────
#  Vega · variables del stack de PRODUCCIÓN
#
#  Este fichero es la PLANTILLA. Se reparte en dos mitades:
#
#   (1) Bloque "gestionado por la CI" → vive en deploy/prod/stack.env, que SÍ
#       está en git. Lo reescribe promote-to-prod.yml al promocionar. Editar
#       esa línea a mano y redesplegar es, precisamente, el rollback.
#
#   (2) Bloque "secretos" → NO va en git. Se pega en Portainer:
#       Stacks → vega-prod → Environment variables (modo avanzado).
#
#  Ningún valor de producción debe coincidir con el de test: ni la contraseña
#  de Postgres, ni el JWT_SECRET, ni la clave de Anthropic.
# ─────────────────────────────────────────────────────────────────────────────

# ── (1) Gestionado por la CI — está en deploy/prod/stack.env ────────────────
# Tag inmutable de la imagen desplegada: el mismo sha-<short> que se validó en
# test. Para hacer rollback, pon aquí el sha- anterior y redespliega el stack.
VEGA_IMAGE_TAG=sha-0000000

# ── (2) Secretos y ajustes del entorno — configúralos en Portainer ──────────

# Base de datos (interna al stack, nunca publicada al exterior).
POSTGRES_USER=vega
POSTGRES_PASSWORD=cambia-esto-en-portainer
POSTGRES_DB=vega

# Entorno y verbosidad. En producción, `info`: `debug` filtra datos de alumnos
# a los logs y multiplica el volumen del json-file driver.
NODE_ENV=production
LOG_LEVEL=info

# Secreto de firma de JWT. Obligatoriamente distinto del de test:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=cambia-esto-en-portainer
JWT_EXPIRES_IN=12h

# Origen público de la PWA (el que ve el navegador tras el proxy inverso).
WEB_ORIGIN=https://vega.ejemplo.es

# Puertos publicados en el host: franja 1800x, distinta de la de test.
VEGA_API_PORT=18000
VEGA_WEB_PORT=18080

# IA. En producción se llama de verdad a la API de Anthropic.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL_TRANSCRIPTION=claude-opus-4-8
AI_MODEL_GRADING=claude-opus-4-8

# Conector LMS: mock | filesystem | moodle3
LMS_CONNECTOR=moodle3
MOODLE_BASE_URL=https://moodle.ejemplo.es
MOODLE_TOKEN=cambia-esto-en-portainer

# Correo de los resúmenes nocturnos del lote.
SMTP_HOST=smtp.ejemplo.es
SMTP_PORT=587
SMTP_USER=vega@ejemplo.es
SMTP_PASSWORD=cambia-esto-en-portainer
SMTP_FROM=vega@ejemplo.es

# Marca de la academia.
BRAND_NAME=Vega

# ── Administrador inicial ────────────────────────────────────────────────────
# Se crea SÓLO en el primer arranque contra una base vacía. Si ya hay usuarios
# no se toca nada: ni recrea al admin borrado ni devuelve la contraseña.
BOOTSTRAP_ADMIN_EMAIL=admin@vega.local
BOOTSTRAP_ADMIN_PASSWORD=cambia-esto-antes-del-primer-arranque
