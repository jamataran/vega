# Fichero GESTIONADO POR LA CI — no lo edites salvo para hacer rollback.
# Lo reescribe .github/workflows/promote-to-prod.yml al promocionar a producción.
#
# Rollback: sustituye el valor por el sha-<short> anterior (lo tienes en el
# historial de git de este mismo fichero), commitea y redespliega el stack.
#
# Valor de arranque: el tag flotante `prod`, hasta la primera promoción.
VEGA_IMAGE_TAG=prod
